from PyQt6.QtWidgets import QApplication, QMainWindow, QWidget, QLabel
from PyQt6.QtGui import QIcon, QPixmap
import os

def getImagePath(imageName):
    path = os.getcwd()
    path = path + ("/Images/"+imageName)
    path = path.replace("\\","/")
    print(path)
    return path


app = QApplication([])

screen = app.primaryScreen()
geometry = screen.availableGeometry()
size = geometry.size()
width = geometry.width()
height = geometry.height()

window = QMainWindow()
window.resize(width, height)
window.setWindowTitle("Flight Cutter")
window.setWindowIcon(QIcon(getImagePath("Plane.ico")))

label = QLabel(window)
pixmap = QPixmap(getImagePath("Europe.jpg"))

# Scale image if you want
label.setPixmap(pixmap)
label.setScaledContents(True)  # image stretches with window
label.resize(int(width*0.75),int(height))

# Move the image inside the window
label.move(0,0)  # x=50, y=50

#white rectangle label
rect = QLabel(window)
rect.resize(int(width*0.25),int(height))
rect.move(int(width*0.75),0)
rect.setStyleSheet("background-color: white;")


window.showMaximized()
app.exec()
